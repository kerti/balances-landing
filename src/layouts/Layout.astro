---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Track your household net worth with monthly balance snapshots — no transaction-by-transaction budgeting.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
