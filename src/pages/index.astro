---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Balances — track your net worth, not your coffee money">
  <main>
    <h1>Balances</h1>
    <p>
      Each month you enter your balances; Balances tracks your net worth. One number per position,
      once a month — no receipt-scanning, no transaction categorising, no bank-sync babysitting.
    </p>
    <p>
      <a href="https://github.com/kerti/balances-v2">See the app &rarr;</a>
    </p>
  </main>
</Layout>
