---
import { GITHUB_URL, DEMO_URL } from '../consts';
---

<header>
  <div class="container bar">
    <a class="wordmark" href="/">
      <img
        class="wordmark-light"
        src="/brand/wordmark-light.svg"
        alt="Balances"
        width="142"
        height="44"
      />
      <img
        class="wordmark-dark"
        src="/brand/wordmark-dark.svg"
        alt="Balances"
        width="142"
        height="44"
      />
    </a>
    <nav>
      <a class="gh" href={GITHUB_URL}>GitHub</a>
      <a class="button button-primary demo" href={DEMO_URL}>Try the demo</a>
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
  }

  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.6875rem;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
  }

  .wordmark img {
    display: none;
    height: 3rem;
    width: auto;
  }

  .wordmark img.wordmark-light {
    display: block;
  }

  @media (prefers-color-scheme: dark) {
    .wordmark img.wordmark-light {
      display: none;
    }

    .wordmark img.wordmark-dark {
      display: block;
    }
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .gh {
    color: var(--muted-foreground);
    text-decoration: none;
    font-weight: 500;
  }

  .gh:hover {
    color: var(--foreground);
  }

  .demo {
    padding: 0.5rem 1rem;
    font-size: 0.9375rem;
    white-space: nowrap;
  }

  @media (max-width: 26rem) {
    .bar {
      padding-inline: 1rem;
    }

    nav {
      gap: 0.5rem;
    }

    .gh {
      white-space: nowrap;
    }

    .demo {
      padding: 0.5rem 0.75rem;
    }
  }

  @media (max-width: 23rem) {
    nav {
      gap: 0.375rem;
    }

    .wordmark img {
      height: 2.5rem;
    }
  }
</style>
