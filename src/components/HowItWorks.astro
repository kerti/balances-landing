---
import { Image } from 'astro:assets';
import snapshotEntry from '../assets/screenshots/snapshot-entry.svg';

const steps = [
  {
    title: 'Add your positions',
    body: 'Bank accounts, property, vehicles, investments, debts — anything your household owns or owes.',
  },
  {
    title: 'Enter month-end balances',
    body: 'One number per position, straight off the statement. Ten minutes at the end of the month.',
  },
  {
    title: 'Watch your net worth',
    body: 'Balances charts it over time, across everything — including the illiquid things no bank sync can see.',
  },
];
---

<section class="container">
  <div class="grid">
    <div class="steps">
      <h2>How it works</h2>
      <ol>
        {
          steps.map((step) => (
            <li>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
    <div class="shot">
      <Image src={snapshotEntry} alt="Entering a month-end balance in Balances on a phone" />
    </div>
  </div>
</section>

<style>
  section {
    padding-block: 4rem;
    border-top: 1px solid var(--border);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 48rem) {
    .grid {
      grid-template-columns: 3fr 2fr;
    }
  }

  h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
  }

  ol {
    list-style: none;
    counter-reset: step;
    margin: 2rem 0 0;
    padding: 0;
    display: grid;
    gap: 1.75rem;
  }

  li {
    counter-increment: step;
    position: relative;
    padding-left: 3.25rem;
  }

  li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0.125rem;
    width: 2.25rem;
    height: 2.25rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--primary);
    color: var(--primary-foreground);
    font-weight: 700;
  }

  h3 {
    font-size: 1.1875rem;
    font-weight: 650;
  }

  li p {
    margin-top: 0.375rem;
    color: var(--muted-foreground);
  }

  .shot {
    max-width: 17rem;
    margin-inline: auto;
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) * 2.2);
    overflow: hidden;
    background: var(--card);
    box-shadow: 0 1.5rem 3rem -1.5rem oklch(0.147 0.004 49.25 / 25%);
  }

  .shot img {
    display: block;
  }
</style>
