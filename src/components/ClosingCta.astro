---
import { DEMO_URL, SELF_HOST_URL } from '../consts';
---

<section>
  <div class="container">
    <h2>See it with your own eyes</h2>
    <p>
      No account to create, nothing to install. The demo is a shared account and resets nightly.
    </p>
    <div class="cta">
      <a class="button button-primary" href={DEMO_URL}>Try the live demo</a>
      <a class="button button-secondary" href={SELF_HOST_URL}>Self-host it</a>
    </div>
  </div>
</section>

<style>
  section {
    border-top: 1px solid var(--border);
  }

  .container {
    padding-block: 4rem;
    max-width: 60rem;
    text-align: center;
  }

  h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
  }

  p {
    margin-top: 1.25rem;
    font-size: 1.0625rem;
    color: var(--muted-foreground);
  }

  .cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }
</style>
