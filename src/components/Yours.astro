---
import { GITHUB_URL, SELF_HOST_URL } from '../consts';
---

<section>
  <div class="container">
    <h2>Yours</h2>
    <p>
      Balances is open-source under AGPL-3.0 and self-hostable with a single
      <code>docker&nbsp;compose&nbsp;up</code>. Your household’s net worth lives where you put it —
      it is not a data product. Back up or export the whole household whenever you like, and use the
      app in English or Bahasa Indonesia.
    </p>
    <div class="cta">
      <a class="button button-primary" href={SELF_HOST_URL}>Read the self-hosting guide</a>
      <a class="button button-secondary" href={GITHUB_URL}>View the source</a>
    </div>
  </div>
</section>

<style>
  section {
    background: var(--secondary);
    border-top: 1px solid var(--border);
  }

  .container {
    padding-block: 4rem;
    max-width: 46rem;
    text-align: center;
  }

  h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--secondary-foreground);
  }

  p {
    margin-top: 1.25rem;
    font-size: 1.0625rem;
    color: var(--muted-foreground);
  }

  code {
    font-size: 0.9375em;
    color: var(--secondary-foreground);
  }

  .cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }
</style>
