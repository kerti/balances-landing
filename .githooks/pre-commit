#!/bin/sh
# Pre-commit secret guard.
#
# Runs `gitleaks protect --staged` against the staged diff so a secret is caught
# before it enters even a local commit. --redact keeps any matched value out of
# the terminal / agent context. If gitleaks isn't installed, we skip with a note
# rather than block — the CI gitleaks job (full history) is the hard gate.
#
# Enable per clone with `scripts/hooks-install.sh` (sets core.hooksPath).
# Bypass is deliberately unsupported as policy: do NOT use `git commit --no-verify`.
set -eu

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit: gitleaks not installed — skipping local scan (CI still enforces)." >&2
  echo "  install: https://github.com/gitleaks/gitleaks#installing" >&2
  exit 0
fi

if ! gitleaks protect --staged --redact --config .gitleaks.toml; then
  echo "✗ gitleaks: a staged change looks like a secret — commit blocked." >&2
  echo "  Remove the secret and re-stage. Do NOT use --no-verify." >&2
  exit 1
fi
exit 0
